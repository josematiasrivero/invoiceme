generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  email          String   @unique
  hashedPassword String   @map("hashed_password")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("users")
}

model Entity {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  type           String
  address        String?
  email          String?
  abaRouting     String?  @map("aba_routing")
  accountNumber  String?  @map("account_number")
  bankName       String?  @map("bank_name")
  bankAddress    String?  @map("bank_address")
  primaryColor   String   @default("#1D4ED8") @map("primary_color")
  invoiceLayout  String   @default("classic") @map("invoice_layout")
  invoicePrefix  String   @unique @map("invoice_prefix")
  defaultServiceDescription String? @map("default_service_description")
  invoiceCounter Int      @default(0) @map("invoice_counter")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  originInvoices      Invoice[] @relation("InvoiceOrigin")
  destinationInvoices Invoice[] @relation("InvoiceDestination")

  @@index([name])
  @@index([type])
  @@map("entities")
}

model Invoice {
  id                 String   @id @default(uuid()) @db.Uuid
  invoiceNumber      String   @unique @map("invoice_number")
  originId           String   @map("origin_id") @db.Uuid
  destinationId      String   @map("destination_id") @db.Uuid
  date               DateTime @default(now()) @db.Date
  quantity           Decimal  @default(1) @db.Decimal(12, 4)
  unitPrice          Decimal  @default(0) @map("unit_price") @db.Decimal(12, 2)
  amount             Decimal  @db.Decimal(12, 2)
  serviceDescription String   @map("service_description")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz

  origin      Entity @relation("InvoiceOrigin", fields: [originId], references: [id], onDelete: Restrict)
  destination Entity @relation("InvoiceDestination", fields: [destinationId], references: [id], onDelete: Restrict)

  @@index([originId])
  @@index([destinationId])
  @@index([date(sort: Desc)])
  @@map("invoices")
}
